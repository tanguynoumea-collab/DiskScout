<UserControl x:Class="DiskScout.Views.Tabs.CloudTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <DockPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Border DockPanel.Dock="Top" Padding="14,10" Background="{StaticResource BackgroundAltBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource ForegroundSubtleBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding Count, Mode=OneWay}" /> <Run Text="racines cloud détectées —" />
                    </TextBlock>
                    <TextBlock Margin="8,0,0,0" Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Physique :" />
                    </TextBlock>
                    <TextBlock Margin="4,0,12,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                               Text="{Binding TotalPhysicalBytes, Converter={StaticResource BytesFormatConverter}}" />
                    <TextBlock Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold" VerticalAlignment="Center">
                        <Run Text="Logique :" />
                    </TextBlock>
                    <TextBlock Margin="4,0,0,0" Foreground="{StaticResource ForegroundSubtleBrush}" FontWeight="SemiBold" VerticalAlignment="Center"
                               Text="{Binding TotalLogicalBytes, Converter={StaticResource BytesFormatConverter}}" />
                </StackPanel>
            </Border>

            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="{StaticResource BackgroundBrush}"
                      Foreground="{StaticResource ForegroundBrush}"
                      BorderBrush="Transparent" BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource BackgroundAltBrush}"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Racine" Binding="{Binding DisplayName}" Width="2.2*" />
                    <DataGridTextColumn Header="Chemin" Binding="{Binding RootPath}" Width="3*" />
                    <DataGridTextColumn Header="Fournisseur" Binding="{Binding Provider}" Width="1.2*" />
                    <DataGridTextColumn Header="Physique (disque)" Binding="{Binding PhysicalDisplay}" Width="1*" SortMemberPath="PhysicalBytes" />
                    <DataGridTextColumn Header="Logique (cloud)" Binding="{Binding LogicalDisplay}" Width="1*" SortMemberPath="LogicalBytes" />
                    <DataGridTextColumn Header="Économie" Binding="{Binding SavingsDisplay}" Width="1*" SortMemberPath="SavingsBytes" />
                    <DataGridTextColumn Header="Hydratation" Binding="{Binding HydrationDisplay}" Width="1.4*" SortMemberPath="HydrationPercent" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
