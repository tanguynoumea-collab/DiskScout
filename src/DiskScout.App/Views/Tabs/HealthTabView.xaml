<UserControl x:Class="DiskScout.Views.Tabs.HealthTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <ScrollViewer Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,16,20,20">
            <StackPanel>

                <!-- ───────  HERO: badge + score + KPIs, one compact row  ─────── -->
                <Border Background="{StaticResource BackgroundAltBrush}" CornerRadius="6"
                        Padding="20,16" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Compact grade badge -->
                        <Grid Grid.Column="0" Width="96" Height="96" VerticalAlignment="Center">
                            <Ellipse Fill="{StaticResource BackgroundBrush}"
                                     Stroke="{Binding GradeBrush}" StrokeThickness="5" />
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding HealthGrade}"
                                           FontSize="32" FontWeight="Bold"
                                           Foreground="{Binding GradeBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding HealthLabel}"
                                           FontSize="10"
                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                           HorizontalAlignment="Center" Margin="0,-3,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Score + summary -->
                        <StackPanel Grid.Column="1" Margin="22,0,22,0" VerticalAlignment="Center">
                            <TextBlock Text="BILAN DE SANTÉ"
                                       FontSize="11"
                                       Foreground="{StaticResource ForegroundSubtleBrush}"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding HealthScore}"
                                           FontSize="42" FontWeight="Bold"
                                           Foreground="{StaticResource ForegroundBrush}" />
                                <TextBlock Text=" / 100"
                                           FontSize="16"
                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                           VerticalAlignment="Bottom" Margin="4,0,0,8" />
                            </StackPanel>
                            <TextBlock Text="{Binding Summary}"
                                       Foreground="{StaticResource ForegroundBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>

                        <!-- KPI stack -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="190">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Disques analysés" Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding DriveCountDisplay}" FontWeight="SemiBold" FontSize="11" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Occupé total" Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding TotalScannedDisplay}" FontWeight="SemiBold" FontSize="11" />
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Récupérable" Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="{Binding PotentialRecoveryBytes, Converter={StaticResource BytesFormatConverter}}" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource AccentBrush}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ───────  ROW : Drive tiles + Recommendations side by side  ─────── -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Disks -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DISQUES"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundSubtleBrush}" Margin="4,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Drives}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundAltBrush}"
                                            Padding="14,12" Margin="0,0,10,10"
                                            CornerRadius="4"
                                            MinWidth="210" Width="210"
                                            BorderBrush="{Binding StatusBrush}" BorderThickness="0,0,0,3">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontWeight="SemiBold" />
                                                <Border Grid.Column="1"
                                                        Background="{Binding StatusBrush}"
                                                        Padding="7,1" CornerRadius="3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" FontSize="10"
                                                               FontWeight="SemiBold" Foreground="White" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding UsedPercentDisplay}"
                                                       FontSize="26" FontWeight="Bold"
                                                       Foreground="{Binding StatusBrush}"
                                                       Margin="0,6,0,0" />
                                            <Border Height="6" Margin="0,4,0,6"
                                                    Background="{StaticResource BackgroundElevatedBrush}"
                                                    CornerRadius="3" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding UsedPercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                        <ColumnDefinition Width="{Binding FreePercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{Binding StatusBrush}" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding FreeDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource ForegroundSubtleBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Recommendations -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ACTIONS RECOMMANDÉES"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundSubtleBrush}" Margin="4,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundAltBrush}"
                                            Padding="14,10" Margin="0,0,0,8"
                                            CornerRadius="4"
                                            BorderBrush="{Binding PriorityBrush}" BorderThickness="4,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource ForegroundBrush}" />
                                                <TextBlock Text="{Binding Hint}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0" />
                                                <TextBlock Text="{Binding TargetHint}"
                                                           FontSize="11" FontStyle="Italic"
                                                           Foreground="{Binding PriorityBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PotentialDisplay}"
                                                       FontWeight="Bold" FontSize="16"
                                                       Foreground="{Binding PriorityBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,0,0"
                                                       Visibility="{Binding HasPotential, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <!-- ───────  Metric cards (4 compact)  ─────── -->
                <TextBlock Text="OPPORTUNITÉS"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundSubtleBrush}" Margin="4,0,0,8" />
                <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,0,0,14">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundAltBrush}"
                                    Margin="0,0,10,0" Padding="14,10" CornerRadius="4"
                                    BorderBrush="{Binding Brush}" BorderThickness="0,0,0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="{StaticResource ForegroundSubtleBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ValueDisplay}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{Binding Brush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ───────  Two columns: extensions + folders  ─────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TOP EXTENSIONS"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundSubtleBrush}" Margin="4,0,0,8" />
                        <Border Background="{StaticResource BackgroundAltBrush}" Padding="14,10" CornerRadius="4">
                            <ItemsControl ItemsSource="{Binding TopExtensions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Extension}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" />
                                            <Border Grid.Column="1" Height="10"
                                                    Background="{StaticResource BackgroundElevatedBrush}"
                                                    CornerRadius="3" ClipToBounds="True" VerticalAlignment="Center">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource AccentBrush}" />
                                                </Grid>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding PercentDisplay}"
                                                       Foreground="{StaticResource ForegroundSubtleBrush}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" FontSize="11"
                                                       MinWidth="50" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TOP DOSSIERS RACINE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundSubtleBrush}" Margin="4,0,0,8" />
                        <Border Background="{StaticResource BackgroundAltBrush}" Padding="14,10" CornerRadius="4">
                            <ItemsControl ItemsSource="{Binding TopFolders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                                           Margin="10,0,0,0" FontSize="11" />
                                            </Grid>
                                            <Border Grid.Row="1" Height="6" Margin="0,4,0,2"
                                                    Background="{StaticResource BackgroundElevatedBrush}"
                                                    CornerRadius="3" ClipToBounds="True">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="{Binding SharePercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource AccentMutedBrush}" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
