<UserControl x:Class="DiskScout.Views.Tabs.LargestFilesTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <DockPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border DockPanel.Dock="Top" Padding="14,10" Background="{StaticResource BackgroundAltBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Top N :" VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundSubtleBrush}" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Width="60"
                             Text="{Binding TopN, UpdateSourceTrigger=LostFocus}"
                             Background="{StaticResource BackgroundElevatedBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="6,4" VerticalAlignment="Center" />
                    <TextBox Grid.Column="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BackgroundElevatedBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="6,4" Margin="14,0,14,0"
                             ToolTip="Filtrer par nom, chemin ou extension" />
                    <TextBlock Grid.Column="3" VerticalAlignment="Center"
                               Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="{Binding Count, Mode=OneWay}" /><Run Text=" fichiers — " />
                        <Run Text="{Binding TotalBytes, Converter={StaticResource BytesFormatConverter}, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                </Grid>
            </Border>
            <DataGrid ItemsSource="{Binding View}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="{StaticResource BackgroundBrush}"
                      Foreground="{StaticResource ForegroundBrush}"
                      BorderBrush="Transparent" BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{StaticResource BackgroundAltBrush}"
                      HorizontalGridLinesBrush="{StaticResource BorderBrush}">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copier le chemin"
                                  Command="{Binding PlacementTarget.DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Taille" Binding="{Binding SizeDisplay}" Width="0.8*" SortMemberPath="SizeBytes" />
                    <DataGridTextColumn Header="Ext" Binding="{Binding Extension}" Width="0.6*" />
                    <DataGridTextColumn Header="Modifié" Binding="{Binding LastModifiedDisplay}" Width="0.8*" SortMemberPath="LastModifiedUtc" />
                    <DataGridTextColumn Header="Chemin" Binding="{Binding FullPath}" Width="4*" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
</UserControl>
