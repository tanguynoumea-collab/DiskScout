<UserControl x:Class="DiskScout.Views.Tabs.QuarantineTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <DockPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border DockPanel.Dock="Top" Padding="14,10" Background="{StaticResource BackgroundAltBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="{Binding Count, Mode=OneWay}" /><Run Text=" entrée(s) — " />
                        <Run Text="{Binding TotalBytes, Converter={StaticResource BytesFormatConverter}, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" occupés" />
                    </TextBlock>
                    <Button Content="Rafraîchir"
                            Command="{Binding RefreshCommand}"
                            Margin="18,0,8,0" />
                    <Button Content="Purger les expirées (&gt; 30 j)"
                            Command="{Binding PurgeExpiredCommand}" />
                </StackPanel>
            </Border>
            <ListBox ItemsSource="{Binding View}"
                     Background="{StaticResource BackgroundBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderThickness="0"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Restaurer vers l'emplacement d'origine"
                                  Command="{Binding PlacementTarget.DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundAltBrush}" Padding="12,8" Margin="0,8,0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding OriginalPath}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding RetentionDisplay}" FontSize="11"
                                               Foreground="{StaticResource ForegroundSubtleBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
