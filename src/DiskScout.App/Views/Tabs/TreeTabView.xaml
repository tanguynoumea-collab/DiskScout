<UserControl x:Class="DiskScout.Views.Tabs.TreeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             xmlns:vm="clr-namespace:DiskScout.ViewModels"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <DockPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Filter + analyze bar -->
            <Border DockPanel.Dock="Top" Padding="14,10" Background="{StaticResource BackgroundAltBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Filtre taille mini (Go) :"
                               Foreground="{StaticResource ForegroundSubtleBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Width="80"
                             Text="{Binding MinSizeGb, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             Background="{StaticResource BackgroundElevatedBrush}"
                             Foreground="{StaticResource ForegroundBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="6,4"
                             VerticalAlignment="Center"
                             ToolTip="Laisser à 0 pour tout afficher. Exemple : 5 = masquer les dossiers &lt; 5 Go." />
                    <TextBlock Text="Go" Foreground="{StaticResource ForegroundSubtleBrush}" VerticalAlignment="Center" Margin="6,0,20,0" />

                    <Button Content="Analyser les types"
                            Command="{Binding AnalyzeDocumentTypesCommand}"
                            Visibility="{Binding IsDocumentAnalysisEnabled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Margin="0,0,8,0" />
                    <Button Content="Réinitialiser l'analyse"
                            Command="{Binding ClearDocumentAnalysisCommand}"
                            Visibility="{Binding IsDocumentAnalysisEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Border>

            <!-- Legend -->
            <Border DockPanel.Dock="Top"
                    Padding="14,8"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Visibility="{Binding IsDocumentAnalysisEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Text="Global disque :" Foreground="{StaticResource ForegroundSubtleBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,14,6" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocPdfBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="PDF " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.PdfPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocXlsxBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="XLSX " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.XlsxPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocRvtBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="RVT " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.RvtPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocTxtBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="TXT " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.TxtPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocDllBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="DLL " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.DllPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocSysBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="SYS " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.SysPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocExeBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="EXE " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.ExePercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,18,6">
                        <Border Width="14" Height="10" Background="{StaticResource DocOtherBrush}" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center"><Run Text="Autres " FontWeight="SemiBold" /><Run Text="{Binding GlobalBreakdown.OtherPercent, StringFormat={}{0:F1}%, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <TreeView ItemsSource="{Binding Roots}"
                      Background="{StaticResource BackgroundBrush}"
                      Foreground="{StaticResource ForegroundBrush}"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="Copier le chemin"
                                              Command="{Binding PlacementTarget.DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                    <Separator />
                                    <MenuItem Header="Supprimer (corbeille / définitif…)"
                                              Command="{Binding PlacementTarget.DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
                        <Grid Margin="0,2" HorizontalAlignment="Stretch">
                            <!-- Name column: 1 share. Size: auto. Bar: 2 shares -> bar = 2/3 of row width -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="160" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="2*" MinWidth="260" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                                       Foreground="{StaticResource ForegroundSubtleBrush}"
                                       VerticalAlignment="Center" Margin="12,0,12,0" MinWidth="70" />

                            <!-- Bar: always size-proportional container; fill = single-colour or multi-segment by doc types -->
                            <Border Grid.Column="2" Height="16" VerticalAlignment="Center"
                                    Background="{StaticResource BackgroundElevatedBrush}" CornerRadius="3" ClipToBounds="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding SharePercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Filled portion proportional to SharePercent -->
                                    <Grid Grid.Column="0">
                                        <!-- Single colour when analysis is off -->
                                        <Border Background="{StaticResource AccentBrush}"
                                                Visibility="{Binding ShowDocumentBreakdown, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                                        <!-- 8-segment doc-type breakdown when analysis is on -->
                                        <Grid Visibility="{Binding ShowDocumentBreakdown, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding PdfPercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding XlsxPercent,  Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding RvtPercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding TxtPercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding DllPercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding SysPercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding ExePercent,   Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                                <ColumnDefinition Width="{Binding OtherPercent, Converter={StaticResource PercentToStarGridLengthConverter}}" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource DocPdfBrush}" />
                                            <Border Grid.Column="1" Background="{StaticResource DocXlsxBrush}" />
                                            <Border Grid.Column="2" Background="{StaticResource DocRvtBrush}" />
                                            <Border Grid.Column="3" Background="{StaticResource DocTxtBrush}" />
                                            <Border Grid.Column="4" Background="{StaticResource DocDllBrush}" />
                                            <Border Grid.Column="5" Background="{StaticResource DocSysBrush}" />
                                            <Border Grid.Column="6" Background="{StaticResource DocExeBrush}" />
                                            <Border Grid.Column="7" Background="{StaticResource DocOtherBrush}" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </DockPanel>
    </Grid>
</UserControl>
