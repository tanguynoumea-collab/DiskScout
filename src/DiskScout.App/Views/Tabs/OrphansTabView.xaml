<UserControl x:Class="DiskScout.Views.Tabs.OrphansTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DiskScout.Views.Controls"
             xmlns:vm="clr-namespace:DiskScout.ViewModels"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <controls:EmptyStatePanel Message="{Binding EmptyStateMessage}"
                                  Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        <DockPanel Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- ───  RECAP TILES (one per category)  ─── -->
            <Border DockPanel.Dock="Top" Padding="14,12" Background="{StaticResource BackgroundAltBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Text="Total : " Foreground="{StaticResource ForegroundSubtleBrush}" VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{Binding Count, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" élément(s) • " />
                                <Run Text="{Binding TotalBytes, Converter={StaticResource BytesFormatConverter}, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:OrphanCategoryGroup}">
                                <Border Background="{StaticResource BackgroundElevatedBrush}"
                                        Margin="0,0,8,0" Padding="12,8"
                                        MinWidth="170" CornerRadius="4"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="0,0,0,3">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource ForegroundSubtleBrush}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding TotalBytesDisplay}"
                                                       FontSize="18" FontWeight="Bold"
                                                       Foreground="{Binding AccentBrush}" />
                                            <TextBlock Text="{Binding CountLabel, StringFormat=  ({0})}"
                                                       Foreground="{StaticResource ForegroundSubtleBrush}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ───  SELECTION BAR  ─── -->
            <Border DockPanel.Dock="Top" Padding="14,8"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource ForegroundBrush}">
                            <Run Text="Sélection :" Foreground="{StaticResource ForegroundSubtleBrush}" />
                            <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text=" élément(s) • " Foreground="{StaticResource ForegroundSubtleBrush}" />
                            <Run Text="{Binding SelectedBytes, Converter={StaticResource BytesFormatConverter}, Mode=OneWay}"
                                 FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="{Binding SortLabel}"
                                Command="{Binding CycleSortModeCommand}"
                                Margin="0,0,14,0"
                                ToolTip="Cycle : Taille ↓ → Score ↓ (plus probable résidu en tête) → Score ↑ (moins risqué en tête)" />
                        <Button Content="Tout sélectionner" Command="{Binding SelectAllCommand}" Margin="0,0,6,0" />
                        <Button Content="Tout décocher" Command="{Binding ClearSelectionCommand}" Margin="0,0,14,0" />
                        <Button Content="🤖 Log IA"
                                Command="{Binding GenerateAiAuditPromptCommand}"
                                IsEnabled="{Binding SelectedCount, Converter={StaticResource ZeroToBoolInverseConverter}}"
                                Margin="0,0,6,0"
                                ToolTip="Copie un prompt dans le presse-papier pour analyser la dangerosité de suppression des éléments sélectionnés (à coller dans ChatGPT / Claude / Gemini / Mistral)." />
                        <Button Content="Purger les sélectionnés"
                                Command="{Binding PurgeSelectedCommand}"
                                IsEnabled="{Binding SelectedCount, Converter={StaticResource ZeroToBoolInverseConverter}}"
                                Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ───  EXPANDABLE GROUPS  ─── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:OrphanCategoryGroup}">
                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                      Background="{StaticResource BackgroundBrush}"
                                      Foreground="{StaticResource ForegroundBrush}"
                                      BorderBrush="Transparent" BorderThickness="0"
                                      Margin="0,6,0,0">
                                <Expander.Header>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding AreAllSelected, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleCategorySelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"
                                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                                  ToolTip="Tout sélectionner dans cette catégorie" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="4" Height="18" Background="{Binding AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedLabel}"
                                                       Foreground="{Binding AccentBrush}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CountLabel}"
                                                       Foreground="{StaticResource ForegroundSubtleBrush}"
                                                       Margin="0,0,14,0" VerticalAlignment="Center" FontSize="12" />
                                            <TextBlock Text="{Binding TotalBytesDisplay}"
                                                       FontWeight="Bold" Foreground="{Binding AccentBrush}"
                                                       FontSize="14" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding Rows}" Margin="22,4,0,6">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:OrphanRow}">
                                            <Border Padding="10,6" Background="Transparent"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="0,0,10,0" />
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Reason}" FontSize="11"
                                                                   Foreground="{StaticResource ForegroundSubtleBrush}" />
                                                    </StackPanel>

                                                    <!-- Phase 10-06: Score badge — only when Diagnostics present (AppData rows). -->
                                                    <Border Grid.Column="2"
                                                            Background="{Binding Risk, Converter={StaticResource RiskLevelToBrushConverter}}"
                                                            CornerRadius="8" Padding="8,2"
                                                            VerticalAlignment="Center" Margin="14,0,0,0"
                                                            MinWidth="38"
                                                            Visibility="{Binding HasDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Border.ToolTip>
                                                            <ToolTip MaxWidth="520">
                                                                <StackPanel>
                                                                    <TextBlock FontWeight="SemiBold">
                                                                        <Run Text="Score : " />
                                                                        <Run Text="{Binding ConfidenceScore, Mode=OneWay}" />
                                                                        <Run Text=" / 100  •  Risque : " />
                                                                        <Run Text="{Binding Risk, Mode=OneWay}" />
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding Diagnostics.Reason}"
                                                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                                                    <ItemsControl ItemsSource="{Binding Diagnostics.TriggeredRules}" Margin="0,4,0,0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock FontSize="11" Margin="0,1">
                                                                                    <Run Text="• " />
                                                                                    <Run Text="{Binding RuleId, Mode=OneWay}" />
                                                                                    <Run Text=" — " />
                                                                                    <Run Text="{Binding Reason, Mode=OneWay}" />
                                                                                </TextBlock>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Border.ToolTip>
                                                        <TextBlock Text="{Binding ScoreBadgeText}"
                                                                   Foreground="White" FontWeight="SemiBold"
                                                                   FontSize="11" HorizontalAlignment="Center" />
                                                    </Border>

                                                    <TextBlock Grid.Column="3" Text="{Binding SizeDisplay}"
                                                               FontWeight="SemiBold" VerticalAlignment="Center"
                                                               Margin="14,0,0,0" />

                                                    <!-- Phase 10-06: "Pourquoi ?" button — only when Diagnostics present. -->
                                                    <Button Grid.Column="4" Content="Pourquoi ?"
                                                            Padding="8,2" FontSize="11" Margin="10,0,0,0"
                                                            VerticalAlignment="Center"
                                                            ToolTip="Détailler les règles et signaux ayant produit ce score"
                                                            Command="{Binding DataContext.ShowDiagnosticsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding HasDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
