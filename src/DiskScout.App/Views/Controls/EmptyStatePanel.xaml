<UserControl x:Class="DiskScout.Views.Controls.EmptyStatePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="460">
            <TextBlock Text="&#xE74C;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="48"
                       Foreground="{StaticResource AccentMutedBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18" />
            <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{StaticResource ForegroundSubtleBrush}"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock Text="Clique sur Scanner dans l'en-tête pour démarrer."
                       Foreground="{StaticResource ForegroundSubtleBrush}"
                       FontSize="12"
                       TextAlignment="Center"
                       Margin="0,10,0,0"
                       Opacity="0.7" />
        </StackPanel>
    </Grid>
</UserControl>
