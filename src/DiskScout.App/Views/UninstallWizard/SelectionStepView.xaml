<UserControl x:Class="DiskScout.Views.UninstallWizard.SelectionStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Command="{Binding CancelCommand}" Width="120" Margin="0,0,8,0" />
                <Button Content="Suivant : Aperçu" Command="{Binding NextCommand}" Width="160" />
            </StackPanel>
        </Border>

        <StackPanel Margin="20" VerticalAlignment="Top">
            <TextBlock Text="Programme à désinstaller" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,12" />

            <Border Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="14">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold"
                               Text="{Binding Target.DisplayName}"
                               Foreground="{StaticResource ForegroundBrush}" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="Éditeur : " />
                        <Run Text="{Binding Target.Publisher}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0" Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="Version : " />
                        <Run Text="{Binding Target.Version}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0" Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="Chemin : " />
                        <Run Text="{Binding Target.InstallLocation}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Margin="0,12,0,0"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="14">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Diagnostic"
                               Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,6" />
                    <TextBlock Foreground="{StaticResource ForegroundSubtleBrush}">
                        <Run Text="Règles éditeur : " />
                        <Run Text="{Binding MatchedRulesSummary}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <CheckBox Margin="0,18,0,0"
                      IsChecked="{Binding PreferSilent}"
                      Foreground="{StaticResource ForegroundBrush}"
                      Content="Préférer une désinstallation silencieuse (si disponible)" />

            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ForegroundSubtleBrush}"
                       FontSize="11" TextWrapping="Wrap"
                       Text="L'assistant va guider la désinstallation : aperçu des résidus connus, exécution du désinstalleur natif, scan post-désinstallation, et confirmation explicite avant suppression DÉFINITIVE des résidus." />
        </StackPanel>
    </DockPanel>
</UserControl>
