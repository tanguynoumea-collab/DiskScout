<UserControl x:Class="DiskScout.Views.UninstallWizard.ReportStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="14,10" Background="{StaticResource BackgroundAltBrush}">
            <TextBlock Text="Rapport de désinstallation" FontSize="14"
                       Foreground="{StaticResource ForegroundBrush}" />
        </Border>
        <Border DockPanel.Dock="Bottom" Padding="14" Background="{StaticResource BackgroundAltBrush}">
            <DockPanel>
                <TextBlock Text="{Binding ExportStatus}"
                           Foreground="{StaticResource ForegroundSubtleBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button Content="Exporter JSON" Command="{Binding ExportJsonCommand}"
                            Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Exporter HTML" Command="{Binding ExportHtmlCommand}"
                            Margin="0,0,8,0" Padding="10,4" />
                    <Button Content="Fermer" Command="{Binding CloseCommand}" Padding="10,4" />
                </StackPanel>
            </DockPanel>
        </Border>
        <ScrollViewer>
            <StackPanel Margin="14">
                <TextBlock Text="{Binding Report.ProgramName, StringFormat='Programme : {0}'}"
                           Foreground="{StaticResource ForegroundBrush}"
                           FontSize="14" Margin="0,0,0,4" />
                <TextBlock Text="{Binding Report.Publisher, StringFormat='Éditeur : {0}'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
                <TextBlock Text="{Binding Report.Version, StringFormat='Version : {0}'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
                <TextBlock Text="{Binding Report.UninstallOutcomeStatus, StringFormat='Désinstalleur natif : {0}'}"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,12,0,0" />
                <TextBlock Text="{Binding Report.UninstallExitCode, StringFormat='Code de sortie : {0}'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
                <TextBlock Text="{Binding Report.UninstallElapsedSeconds, StringFormat='Durée : {0:F1} s'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
                <TextBlock Text="{Binding Report.ResidueCount, StringFormat='Résidus détectés : {0}'}"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,12,0,0" />
                <TextBlock Text="{Binding Report.ResidueBytes, StringFormat='Taille totale résidus : {0} octets'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
                <TextBlock Text="{Binding Report.DeletedSuccessCount, StringFormat='Supprimés (succès) : {0}'}"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,12,0,0" />
                <TextBlock Text="{Binding Report.DeletedFailureCount, StringFormat='Supprimés (échecs) : {0}'}"
                           Foreground="{StaticResource ForegroundBrush}" />
                <TextBlock Text="{Binding Report.DeletedBytesFreed, StringFormat='Espace libéré : {0} octets'}"
                           Foreground="{StaticResource ForegroundSubtleBrush}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
