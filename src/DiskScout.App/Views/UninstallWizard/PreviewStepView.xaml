<UserControl x:Class="DiskScout.Views.UninstallWizard.PreviewStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Précédent" Command="{Binding BackCommand}" Width="120" Margin="0,0,8,0" />
                <Button Content="Annuler" Command="{Binding CancelCommand}" Width="120" Margin="0,0,8,0" />
                <Button Content="Suivant : exécuter le désinstalleur"
                        Command="{Binding NextCommand}" Width="240" />
            </StackPanel>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Trace d'installation"
                       FontWeight="SemiBold" FontSize="14"
                       Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,8" />
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="Règles éditeur connues"
                       FontWeight="SemiBold" FontSize="14"
                       Foreground="{StaticResource ForegroundBrush}" Margin="14,0,0,8" />

            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <ListBox ItemsSource="{Binding TraceEvents}"
                         FontFamily="Consolas" FontSize="12"
                         Background="Transparent"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderThickness="0" />
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Margin="14,0,0,0"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <ListBox ItemsSource="{Binding RuleHits}"
                         FontFamily="Consolas" FontSize="12"
                         Background="Transparent"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderThickness="0" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
