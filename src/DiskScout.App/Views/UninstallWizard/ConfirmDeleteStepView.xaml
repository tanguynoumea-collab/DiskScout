<UserControl x:Class="DiskScout.Views.UninstallWizard.ConfirmDeleteStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiskScout.ViewModels.UninstallWizard"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource ForegroundBrush}">
                        <Run Text="Sélection : " />
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" élément(s), " />
                        <Run Text="{Binding TotalSelectedDisplay, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource ForegroundSubtleBrush}"
                               Text="Toutes les cases sont décochées par défaut. Une confirmation modale IRRÉVERSIBLE est requise." />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler" Command="{Binding CancelCommand}" Width="120" Margin="0,0,8,0" />
                    <Button Content="Confirmer la suppression DÉFINITIVE"
                            Command="{Binding ConfirmCommand}" Width="280" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="Cocher les éléments à supprimer DÉFINITIVEMENT (pas de quarantaine, pas de corbeille)"
                       FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap"
                       Foreground="{StaticResource ForegroundBrush}" Margin="0,0,0,10" />

            <Border Grid.Row="1"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <TreeView ItemsSource="{Binding Roots}"
                          Background="Transparent"
                          Foreground="{StaticResource ForegroundBrush}"
                          BorderThickness="0">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:ResidueTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsThreeState="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SizeDisplay}"
                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                           VerticalAlignment="Center" Margin="14,0,0,0" />
                                <TextBlock Text="{Binding TrustDisplay}"
                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                           VerticalAlignment="Center" Margin="14,0,0,0" />
                                <TextBlock Text="{Binding Reason}"
                                           Foreground="{StaticResource ForegroundSubtleBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
