<UserControl x:Class="DiskScout.Views.UninstallWizard.RunUninstallStepView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Précédent" Command="{Binding BackCommand}" Width="120" Margin="0,0,8,0" />
                <Button Content="Annuler" Command="{Binding CancelCommand}" Width="120" Margin="0,0,8,0" />
                <Button Content="Lancer le désinstalleur" Command="{Binding RunCommand}" Width="200" Margin="0,0,8,0" />
                <Button Content="Suivant : scan résidus" Command="{Binding NextCommand}" Width="200" />
            </StackPanel>
        </Border>

        <DockPanel Margin="20">
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                <TextBlock Text="{Binding Status}" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap" />
            </Border>

            <Border Background="{StaticResource BackgroundAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4">
                <ListBox ItemsSource="{Binding OutputLines}"
                         FontFamily="Consolas" FontSize="12"
                         Background="Transparent"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
            </Border>
        </DockPanel>
    </DockPanel>
</UserControl>
