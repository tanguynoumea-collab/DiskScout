<Window x:Class="DiskScout.Views.OrphanDiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pourquoi cette détection ?"
        Width="700" Height="540"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">

        <!-- Header: full path + size -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,12">
            <StackPanel>
                <TextBlock Text="{Binding FullPath}"
                           FontSize="13" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource ForegroundBrush}" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Parent significatif : "
                               Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                    <TextBlock Text="{Binding ParentSignificantPath}"
                               Foreground="{StaticResource ForegroundBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="Taille : "
                               Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                    <TextBlock Text="{Binding SizeDisplay}"
                               Foreground="{StaticResource ForegroundBrush}" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,14,0" />
                    <TextBlock Text="Dernière modification : "
                               Foreground="{StaticResource ForegroundSubtleBrush}" FontSize="11" />
                    <TextBlock Text="{Binding LastWriteDisplay}"
                               Foreground="{StaticResource ForegroundBrush}" FontSize="11" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Bottom action bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Lecture seule — DiskScout ne supprime jamais."
                           Foreground="{StaticResource ForegroundSubtleBrush}"
                           FontStyle="Italic" FontSize="11"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Fermer"
                        MinWidth="90"
                        Click="OnCloseClicked"
                        IsCancel="True"
                        IsDefault="True" />
            </Grid>
        </Border>

        <!-- Body: score banner + sections -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="14,12">

                <!-- Score banner -->
                <Border Background="{Binding Risk, Converter={StaticResource RiskLevelToBrushConverter}}"
                        CornerRadius="6" Padding="14,10" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                            <TextBlock Text="{Binding ConfidenceScore}"
                                       Foreground="White" FontSize="36" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="/ 100"
                                       Foreground="White" FontSize="11" Opacity="0.85"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Risque : "
                                           Foreground="White" Opacity="0.85" FontSize="13" />
                                <TextBlock Text="{Binding RiskLabel}"
                                           Foreground="White" FontSize="13" FontWeight="SemiBold"
                                           Margin="0,0,18,0" />
                                <TextBlock Text="Action recommandée : "
                                           Foreground="White" Opacity="0.85" FontSize="13" />
                                <TextBlock Text="{Binding ActionLabel}"
                                           Foreground="White" FontSize="13" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Catégorie : "
                                           Foreground="White" Opacity="0.85" FontSize="11" />
                                <TextBlock Text="{Binding CategoryLabel}"
                                           Foreground="White" FontSize="11" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="{Binding Reason}"
                                       Foreground="White" Opacity="0.95" FontSize="11"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Triggered rules -->
                <TextBlock Text="Règles déclenchées"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,0,0,4" />
                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Background="{StaticResource BackgroundElevatedBrush}"
                        Padding="10,8" Margin="0,0,0,14">
                    <ItemsControl ItemsSource="{Binding TriggeredRulesLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="12" Margin="0,2"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Matchers -->
                <TextBlock Text="Signaux des matchers (Service / Driver / Appx / Registre)"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,0,0,4" />
                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Background="{StaticResource BackgroundElevatedBrush}"
                        Padding="10,8">
                    <ItemsControl ItemsSource="{Binding MatchedSourcesLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           FontSize="12" Margin="0,2"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
