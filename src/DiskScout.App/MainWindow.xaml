<Window x:Class="DiskScout.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:DiskScout.Views.Tabs"
        xmlns:vm="clr-namespace:DiskScout.ViewModels"
        Title="{Binding WindowTitle}"
        Icon="/DiskScout;component/Assets/DiskScout.ico"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource ForegroundBrush}">
    <DockPanel LastChildFill="True">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource DiskScoutLogoImage}" Width="28" Height="28"
                           Margin="0,0,12,0" VerticalAlignment="Center" />
                    <TextBlock Text="DiskScout" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <TextBlock Text="Disques :" Foreground="{StaticResource ForegroundSubtleBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ItemsControl ItemsSource="{Binding Orchestrator.Drives}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DriveSelectionItemViewModel}">
                                <CheckBox Content="{Binding DisplayText}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Foreground="{StaticResource ForegroundBrush}"
                                          Margin="0,0,14,0" VerticalAlignment="Center" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Scanner"
                            Command="{Binding Orchestrator.StartScanCommand}"
                            IsEnabled="{Binding Orchestrator.IsScanning, Converter={StaticResource InverseBooleanConverter}}"
                            Margin="0,0,8,0" />
                    <Button Content="Annuler"
                            Command="{Binding Orchestrator.CancelScanCommand}"
                            IsEnabled="{Binding Orchestrator.CanCancel}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Orchestrator.ProgressText}"
                           Foreground="{StaticResource ForegroundBrush}" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,14,0" />
                <ProgressBar Grid.Row="0" Grid.Column="1"
                             Value="{Binding Orchestrator.ProgressPercent, Mode=OneWay}"
                             IsIndeterminate="{Binding Orchestrator.IsScanning}"
                             Height="6" Minimum="0" Maximum="100"
                             Background="{StaticResource BackgroundElevatedBrush}"
                             Foreground="{StaticResource AccentBrush}" BorderBrush="Transparent" />
                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding Orchestrator.CurrentPath}"
                           Foreground="{StaticResource ForegroundSubtleBrush}"
                           FontSize="11" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BackgroundAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,6">
            <TextBlock Text="{Binding Orchestrator.StatusMessage}"
                       Foreground="{StaticResource ForegroundSubtleBrush}" />
        </Border>

        <!-- Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    Background="{StaticResource BackgroundBrush}" BorderThickness="0">
            <TabItem Header="Programmes">
                <tabs:ProgramsTabView DataContext="{Binding Programs}" />
            </TabItem>
            <TabItem Header="Rémanents">
                <tabs:OrphansTabView DataContext="{Binding Orphans}" />
            </TabItem>
            <TabItem Header="Arborescence">
                <tabs:TreeTabView DataContext="{Binding Tree}" />
            </TabItem>
            <TabItem Header="Gros fichiers">
                <tabs:LargestFilesTabView DataContext="{Binding LargestFiles}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
